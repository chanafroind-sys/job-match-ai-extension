# Copy this file to .env and fill in your values
ANTHROPIC_API_KEY=sk-ant-...
GUMROAD_PRODUCT_ID=YOUR_PRODUCT_ID_HERE
MAX_DEVICES_PER_KEY=3
MONTHLY_USAGE_LIMIT=100
PORT=8000
# Optional — defaults to a local SQLite file (server-python/dev.db) when unset.
# In production this is a Render-managed Postgres connection string.
DATABASE_URL=
