# Copy this file to .env and fill in your values
ANTHROPIC_API_KEY=sk-ant-...
GUMROAD_PRODUCT_ID=YOUR_PRODUCT_ID_HERE
MAX_DEVICES_PER_KEY=3
MONTHLY_USAGE_LIMIT=100
PORT=8000
# Optional — defaults to a local SQLite file (server-python/dev.db) when unset.
# In production this is a Render-managed Postgres connection string.
DATABASE_URL=

# Employee referrals — Google Sheet (published to the web as CSV) backing the
# `employees` table lazy sync. Leave blank to disable the sync entirely.
EMPLOYEES_SHEET_CSV_URL=

# Employee referrals — system-account SMTP for the referral notification and
# accept/decline emails. Any SMTP provider works; nothing is vendor-specific.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
